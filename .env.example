# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string — requires a local PostgreSQL instance
# Create the DB manually: createdb forge_db
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/forge_db"

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET="replace-with-a-secure-random-string-min-32-chars"
# Token expiry — e.g. 7d, 24h, 1h
JWT_EXPIRES_IN="7d"

# ─── Session ──────────────────────────────────────────────────────────────────
# Name of the HTTP-only session cookie
SESSION_COOKIE_NAME="forge_session"
# Secure cookie flag — set to true in production (requires HTTPS)
SESSION_COOKIE_SECURE="false"

# ─── Socket.io ────────────────────────────────────────────────────────────────
# Port the Socket.io server listens on
SOCKET_PORT="3001"
# CORS origin allowed for socket connections
SOCKET_CORS_ORIGIN="http://localhost:3000"

# ─── Application ──────────────────────────────────────────────────────────────
PORT="3000"
NODE_ENV="development"
# Public URL — used for absolute URL generation
NEXT_PUBLIC_APP_URL="http://localhost:3000"
