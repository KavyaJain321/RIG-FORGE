# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string — requires a local PostgreSQL instance
# Create the DB manually: createdb forge_db
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/forge_db"

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET="replace-with-a-secure-random-string-min-32-chars"
# Token expiry — e.g. 7d, 24h, 1h
JWT_EXPIRES_IN="7d"

# ─── Session ──────────────────────────────────────────────────────────────────
# Name of the HTTP-only session cookie
SESSION_COOKIE_NAME="forge_session"
# Secure cookie flag — set to true in production (requires HTTPS)
SESSION_COOKIE_SECURE="false"

# ─── Socket.io ────────────────────────────────────────────────────────────────
# Port the Socket.io server listens on
SOCKET_PORT="3001"
# CORS origin allowed for socket connections
SOCKET_CORS_ORIGIN="http://localhost:3000"

# ─── Application ──────────────────────────────────────────────────────────────
PORT="3000"
NODE_ENV="development"
# Public URL — used for absolute URL generation
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Forgie (AI Assistant) — optional, enables the in-app chatbot ────────────
# Set ASSISTANT_ENABLED=false to disable the whole feature.
# Each *_API_KEYS variable is a COMMA-SEPARATED list of API keys.
# Forgie rotates within a provider and falls back across providers.

ASSISTANT_ENABLED="false"

# Sign up free at https://console.groq.com (key starts with gsk_)
GROQ_API_KEYS=""
# Sign up free at https://aistudio.google.com/app/apikey (key starts with AIza)
GEMINI_API_KEYS=""
# Sign up free at https://cloud.cerebras.ai (key starts with csk-)
CEREBRAS_API_KEYS=""

# Provider preference (comma-separated). Forgie tries them in this order.
ASSISTANT_PROVIDER_ORDER="groq,gemini,cerebras"

# Default models per provider
GROQ_MODEL="llama-3.3-70b-versatile"
GEMINI_MODEL="gemini-flash-latest"
CEREBRAS_MODEL="gpt-oss-120b"

# Soft rate-limit per user (messages per hour)
ASSISTANT_USER_MSG_PER_HOUR="30"

# Shared secret for cron-driven endpoints (daily-log drafts, standup digest,
# project-health watchdog). External cron services (cron-job.org, GitHub
# Actions) hit /api/cron/* and must include header: x-cron-secret: <value>.
# Use a long random string in production.
CRON_SECRET=""

# ─── GitHub integration (optional) ────────────────────────────────────────────
# When both are set, Forgie can read repos/commits/PRs/issues/code/files and
# (with user confirmation) create new repos or file issues.
# Token: fine-grained PAT, resource owner = your org, repo access = all repos,
#   permissions = Contents/Issues read+write, Pull requests read, Metadata read,
#   Administration read+write (only needed for create-repo).
# Create at https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=""
GITHUB_ORG=""

# ─── Google Calendar + Meet integration (optional) ────────────────────────────
# When all three are set, employees can click "Connect Google" on their profile
# to let Forgie schedule meetings, find shared free time, and auto-generate
# Meet links on their behalf.
#
# Setup:
#   1. Google Cloud Console → enable Calendar API
#   2. Create OAuth 2.0 Web Application credentials
#   3. Add authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
#   4. Copy Client ID + Secret here
#
# Required scopes (configured in the OAuth consent screen):
#   calendar.events, calendar.freebusy, openid email profile
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Hidden developer dashboard (/dashboard/dev) access allowlist.
# Comma-separated emails, case-insensitive. NOT tied to role.
DEV_DASHBOARD_EMAILS=

# Extra companies for the dev console's cross-company switcher (beyond the
# built-in rig360 + trijya). JSON array of objects:
#   { "id", "label", "schema", "organizationId"?, "databaseUrl"? }
# Omit databaseUrl to reuse DATABASE_URL with the schema swapped (same DB, other
# schema). Set databaseUrl for a company that lives on its own database.
# Example: [{"id":"trijya","label":"TRIJYA FORGE","schema":"public","organizationId":"trijya"}]
DEV_INSTANCES=
