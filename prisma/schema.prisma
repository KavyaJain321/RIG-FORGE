generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

enum UserStatus {
  WORKING
  NOT_WORKING
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum MessageVisibility {
  TEAM       // all project members
  LEAD_ADMIN // only project lead + admins
}

enum NotificationType {
  WELCOME
  TICKET_RAISED
  TICKET_ACCEPTED
  TICKET_COMPLETED
  TICKET_CANCELLED
  TASK_ASSIGNED
  TASK_DONE
  TASK_OVERDUE
  PROJECT_UPDATE
  PROJECT_ANNOUNCEMENT
  PROJECT_MEMBER_ADDED
  PROJECT_LEAD_ASSIGNED
  ONBOARDING_APPROVED
  ONBOARDING_PENDING
  ADMIN_MESSAGE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique      // RIG login identifier (e.g. name@rigforge.com) — NOT a real mailbox
  personalEmail String?                 // deliverable Gmail (manual bootstrap). Authoritative source is the connected GoogleIntegration.email when present.
  whatsappNumber String?   @unique       // WhatsApp number in E.164 format (+91XXXXXXXXXX). Unique so inbound WA messages resolve to exactly one user. (Nullable → many users may have none.)
  passwordHash  String
  role          Role
  avatarUrl          String?
  currentStatus      UserStatus @default(NOT_WORKING)
  isActive           Boolean    @default(true)
  isOnboarding       Boolean    @default(false)
  tempPassword       String?    // plaintext temp password shown to admins; cleared after first change
  mustChangePassword Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  projects        ProjectMember[]
  projectsLed     Project[]       @relation("ProjectLead")
  tasks           Task[]
  threads         ThreadMessage[]
  notifications   Notification[]
  ticketsRaised   Ticket[]        @relation("TicketsRaised")
  ticketsHelped   Ticket[]        @relation("TicketsHelped")
  ticketComments  TicketComment[]
  dailyLogs       DailyLog[]
  dailyActivities DailyActivity[]
  conversations   AssistantConversation[]
  assistantUsage  AssistantUsage[]
  auditLogs       AssistantAuditLog[]
  dailyLogDrafts  DailyLogDraft[]
  googleIntegration GoogleIntegration?
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus
  priority    Priority
  deadline    DateTime?
  leadId      String?
  links       Json?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lead    User?           @relation("ProjectLead", fields: [leadId], references: [id])
  members ProjectMember[]
  tasks   Task[]
  thread  ProjectThread?
  tickets Ticket[]

  @@index([leadId])
}

model ProjectMember {
  id           String   @id @default(cuid())
  userId       String
  projectId    String
  contribution Float    @default(0)
  joinedAt     DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
  @@index([projectId])
}

model Task {
  id             String     @id @default(cuid())
  title          String
  description    String?
  expectedOutput String?
  status         TaskStatus
  priority       Priority
  assigneeId     String?
  projectId      String
  dueDate        DateTime?
  completedAt    DateTime?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  assignee User?      @relation(fields: [assigneeId], references: [id])
  project  Project    @relation(fields: [projectId], references: [id])
  thread   TaskThread?

  @@index([projectId])
  @@index([assigneeId])
}

model Ticket {
  id          String       @id @default(cuid())
  title       String
  description String
  projectId   String
  raisedById  String
  helperId    String?
  status      TicketStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  acceptedAt  DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  project  Project @relation(fields: [projectId], references: [id])
  raisedBy User    @relation("TicketsRaised", fields: [raisedById], references: [id])
  helper   User?   @relation("TicketsHelped", fields: [helperId], references: [id])
  comments TicketComment[]

  @@index([projectId])
  @@index([raisedById])
  @@index([status])
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@index([authorId])
}

model DailyLog {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  workSummary String
  notes       String?
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
}

model DailyActivity {
  id         String    @id @default(cuid())
  userId     String
  date       DateTime  @db.Date
  wasActive  Boolean   @default(false)
  lastSeenAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
}

model WeeklyReport {
  id            String   @id @default(cuid())
  reportType    String   @default("WEEKLY")   // WEEKLY | PROJECT | EMPLOYEE
  label         String?
  weekStart     DateTime @db.Date
  weekEnd       DateTime @db.Date
  generatedAt   DateTime @default(now())
  generatedById String?
  filterIds     String[] @default([])
  snapshot      Json

  @@index([weekStart])
  @@index([reportType])
}

model TaskThread {
  id        String   @id @default(cuid())
  taskId    String   @unique
  createdAt DateTime @default(now())

  task     Task            @relation(fields: [taskId], references: [id])
  messages ThreadMessage[]
}

model ProjectThread {
  id        String   @id @default(cuid())
  projectId String   @unique
  createdAt DateTime @default(now())

  project  Project         @relation(fields: [projectId], references: [id])
  messages ThreadMessage[]
}

model ThreadMessage {
  id              String            @id @default(cuid())
  content         String
  authorId        String
  taskThreadId    String?
  projectThreadId String?
  visibility      MessageVisibility @default(TEAM)
  fileUrl         String?
  fileName        String?
  fileType        String?           // "link" | "file"
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  author        User           @relation(fields: [authorId], references: [id])
  taskThread    TaskThread?    @relation(fields: [taskThreadId], references: [id])
  projectThread ProjectThread? @relation(fields: [projectThreadId], references: [id])

  @@index([taskThreadId])
  @@index([projectThreadId])
  @@index([authorId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  linkTo    String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
}

// ─── Forgie (AI Assistant) ────────────────────────────────────────────────────
// Tables that power the in-app AI chatbot. Conversations are per-user.
// AssistantMessage stores both user prompts and AI responses (role = USER / ASSISTANT).
// AssistantUsage tracks per-user, per-day token spend for soft rate-limiting.
// AssistantResponseCache lets common queries skip the LLM round-trip.

enum AssistantMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

// Where a Forgie conversation originated. WEB is the in-app chat; WHATSAPP
// is the inbound WA flow handled by /api/whatsapp/incoming. Used to keep
// WA conversations separate from web ones in the history sidebar and to
// gate behaviour (e.g. WA replies are short-form, no proposal cards).
enum AssistantChannel {
  WEB
  WHATSAPP
}

model AssistantConversation {
  id        String   @id @default(cuid())
  userId    String
  channel   AssistantChannel @default(WEB)
  title     String?  // auto-summarized after first exchange, null until then
  isPinned  Boolean  @default(false)
  isArchived Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id])
  messages  AssistantMessage[]
  auditLogs AssistantAuditLog[]

  @@index([userId])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([userId, channel])
}

model AssistantMessage {
  id             String               @id @default(cuid())
  conversationId String
  role           AssistantMessageRole
  content        String               // the text the user saw / sent
  toolCalls      Json?                // structured tool invocations, if any
  toolResults    Json?                // outputs returned by tools
  provider       String?              // "groq" | "gemini" | "cerebras" | null for USER
  model          String?              // e.g. "llama-3.3-70b-versatile"
  inputTokens    Int?
  outputTokens   Int?
  latencyMs      Int?
  createdAt      DateTime             @default(now())

  conversation AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model AssistantUsage {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime @db.Date
  hour         Int      // 0-23 — for per-hour rate limiting
  messageCount Int      @default(0)
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  provider     String   // "groq" | "gemini" | "cerebras"

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date, hour, provider])
  @@index([userId, date])
}

model AssistantResponseCache {
  id            String   @id @default(cuid())
  cacheKey      String   @unique  // hash of (userId|query|userContext)
  response      String              // the cached final assistant text
  toolResults   Json?               // any tool results that produced it
  hits          Int      @default(0)
  expiresAt     DateTime            // typically createdAt + 5 min
  createdAt     DateTime @default(now())

  @@index([expiresAt])
}

// Every AI-triggered write action is recorded here. Lets admins answer
// "what did Forgie do this week", and gives us a forensic trail if a
// write turns out to be wrong. Records both successes and failures.
model AssistantAuditLog {
  id             String   @id @default(cuid())
  userId         String                  // the human who confirmed the action
  conversationId String?
  action         String                  // "create_task", "create_ticket", etc.
  args           Json                    // exact arguments executed
  result         Json?                   // returned data on success
  success        Boolean  @default(true)
  error          String?
  createdAt      DateTime @default(now())

  user           User                    @relation(fields: [userId], references: [id])
  conversation   AssistantConversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt])
}

// AI-drafted daily logs awaiting user approval. Created by the
// /api/cron/daily-log-drafts job at ~6pm IST; consumed via
// /api/assistant/daily-log-draft (GET to fetch, POST to approve/edit).
enum DailyLogDraftStatus {
  PENDING
  APPROVED
  DISMISSED
}

model DailyLogDraft {
  id              String              @id @default(cuid())
  userId          String
  date            DateTime            @db.Date
  draftSummary    String              // the AI-drafted text
  draftNotes      String?
  evidence        Json                // raw activity used to draft (for transparency)
  status          DailyLogDraftStatus @default(PENDING)
  approvedAt      DateTime?
  dismissedAt     DateTime?
  createdDailyLogId String?           // link back if the user approved + a DailyLog was created
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([status])
}

// Per-user Google OAuth tokens. Stored after the user clicks "Connect
// Google" on their profile. Used by gcal_* tools to make calendar
// API calls on their behalf. Refresh tokens never expire unless the
// user revokes; access tokens expire in 1h and are auto-refreshed.
//
// SECURITY NOTE: For v0, tokens are stored as plain text. Production
// hardening should encrypt at column level (or use a managed vault).
// The DB connection itself is TLS to Supabase, so they're protected
// in transit and at rest by Supabase's encryption.
model GoogleIntegration {
  id            String   @id @default(cuid())
  userId        String   @unique
  email         String              // the Google email they connected
  accessToken   String              // expires ~1h
  refreshToken  String              // long-lived
  expiresAt     DateTime
  scopes        String              // space-separated granted scopes
  connectedAt   DateTime @default(now())
  lastUsedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Baileys auth state for the WhatsApp bridge.
// Owned by /whatsapp-bridge — Prisma only needs to know about it so it
// doesn't try to drop the table on `db push`.
model WhatsappAuth {
  id        String   @id
  data      String
  updatedAt DateTime @default(now()) @db.Timestamp(6)
}

// AI-generated daily team standup. One per day. Shown on the
// /dashboard as a card; written by /api/cron/standup-digest at ~9am IST.
model StandupDigest {
  id              String   @id @default(cuid())
  date            DateTime @db.Date @unique
  summary         String              // the AI-drafted digest text
  metrics         Json                // raw aggregate numbers used to generate it
  generatedById   String?             // null = AI-generated by cron
  generatedAt     DateTime @default(now())

  @@index([date(sort: Desc)])
}
